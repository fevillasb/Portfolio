  <!-- ABOUT -->
  <section class="section about" id="about">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-num">01</span>
        <h2>About</h2>
        <div class="section-line"></div>
      </div>
      <div class="about-grid">
        <div class="about-bio">
          <p>
            Mechanical Engineering student at the <strong>University at Buffalo</strong>, expected May 2027.
            I work at the intersection of hardware, embedded systems, and mechanical design —
            turning rough ideas into functional, testable prototypes.
          </p>
          <p>
            Currently leading electronics integration for UB ASME's rover competition,
            where I design power systems, program microcontrollers, and build mechanisms
            that actually work under pressure.
          </p>
          <div class="edu-block">
            <div class="edu-label">// Education</div>
            <div class="edu-degree">B.S. Mechanical Engineering</div>
            <div class="edu-school">University at Buffalo · Expected May 2027</div>
          </div>
        </div>
        <div class="about-skills">
          <div class="skill-col">
            <div class="skill-label">// Robotics & Embedded</div>
            <ul>
